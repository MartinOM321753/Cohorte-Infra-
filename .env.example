# Cohorte-Infra — plantilla de variables de entorno
# Copia este archivo como ".env" (mismo directorio que docker-compose.yml) y
# completa los valores reales. NUNCA subas ".env" al repositorio — ya esta en .gitignore.
#
# En Jenkins, este archivo NO se versiona con valores reales: el pipeline lo genera
# en el workspace a partir de credenciales configuradas en Jenkins (ver README.md).

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_USER_NAME=root
DB_PASSWORD=cambia-esta-contrasena

# ── MinIO (almacenamiento de objetos) ─────────────────────────────────────────
MINIO_ACCESS_KEY=cambia-este-usuario
MINIO_SECRET_KEY=cambia-esta-contrasena

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera una clave nueva, ej: openssl rand -base64 32
SECRET_KEY=genera-una-clave-base64-de-256-bits

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
MAIL_USERNAME=tu-usuario-smtp
MAIL_PASSWORD=tu-password-smtp
MAIL_FROM=notificaciones@tu-dominio.com

# ── URL pública del frontend (usada en emails y CORS del backend) ─────────────
FRONTEND_URL=https://tu-dominio.com

# ── Cookies de sesión ──────────────────────────────────────────────────────────
# true en produccion (requiere HTTPS); false solo para depurar en HTTP local.
COOKIE_SECURE=true

# ── Perfil de Spring activo en el backend ──────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Frontend build (Vite — baked en tiempo de build del contenedor) ───────────
# /api → nginx del contenedor frontend proxía al backend (Docker)
VITE_API_URL=/api
